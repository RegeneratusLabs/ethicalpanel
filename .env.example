# Required: DeepSeek API key (Anthropic-compatible endpoint)
DEEPSEEK_API_KEY=sk-...

# Optional overrides (defaults shown)
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
DEEPSEEK_MODEL=deepseek-v4-flash
IDEA_MAX_LENGTH=5000
LOG_LEVEL=INFO
REQUEST_TIMEOUT_S=60

# Set to 1 to enable the real-LLM smoke test (also requires DEEPSEEK_API_KEY)
# EFC_RUN_SMOKE=1
